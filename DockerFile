FROM node:20-bookworm-slim

# Install Python, pip, ffmpeg, and curl (for downloading yt-dlp)
RUN apt-get update && apt-get install -y \
    python3 \
    python3-pip \
    ffmpeg \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Install yt-dlp via pip (using --break-system-packages since Debian 12 restricts global pip installs)
RUN pip3 install --break-system-packages --upgrade yt-dlp

WORKDIR /app

COPY package*.json ./
RUN npm ci

COPY . .
RUN npm run build

ENV YTDLP_BIN=yt-dlp
ENV NODE_ENV=production
ENV PORT=3000

EXPOSE 3000

CMD ["npm", "start"]